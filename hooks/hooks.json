{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/userpromptsubmit-superpower-entry\"",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-superpower-progress\"",
            "async": true,
            "asyncRewake": true,
            "rewakeSummary": "Superpower progress line missing"
          }
        ]
      }
    ]
  }
}
