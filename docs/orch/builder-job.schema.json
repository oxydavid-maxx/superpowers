{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superpowers.local/orch/builder-job.schema.json",
  "title": "Superpower External Builder Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "phase",
    "builder_session",
    "head_sha",
    "allowed_paths",
    "forbidden_paths",
    "instructions",
    "expected_ack"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "const": "phase-3-build"
    },
    "builder_session": {
      "type": "string",
      "minLength": 1,
      "description": "Runtime-selected builder session id/name. Never hardcode a specific session in the skill."
    },
    "head_sha": {
      "type": "string",
      "minLength": 7
    },
    "spec_path": {
      "type": "string"
    },
    "verification_plan_path": {
      "type": "string",
      "default": ".superpowers/verify/test-design.json"
    },
    "implementation_plan_path": {
      "type": "string"
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "default": [
        "docs/superpowers/specs/**",
        ".superpowers/verify/**",
        ".superpowers/release/**"
      ]
    },
    "instructions": {
      "type": "string",
      "minLength": 1
    },
    "expected_ack": {
      "type": "string",
      "pattern": "^\\.superpowers/orch/outbox/.+\\.ack\\.json$"
    }
  }
}
