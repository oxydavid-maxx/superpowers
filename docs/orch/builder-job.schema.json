{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://superpowers.local/orch/builder-job.schema.json",
  "title": "Superpower External Builder Job",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "job_id",
    "phase",
    "builder_session",
    "head_sha",
    "allowed_paths",
    "forbidden_paths",
    "instructions",
    "expected_ack"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "job_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "const": "phase-3-build"
    },
    "builder_session": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "session_name",
        "user_specified",
        "handoff_channel"
      ],
      "properties": {
        "type": {
          "const": "claude_web",
          "description": "External S4 builder handoff must use the user-specified Claude web session, not Claude CLI."
        },
        "session_name": {
          "type": "string",
          "minLength": 1,
          "description": "User-specified Claude web session name, resolved by the orchestrator from the visible Claude Code UI."
        },
        "user_specified": {
          "const": true
        },
        "handoff_channel": {
          "const": "chrome",
          "description": "The orchestrator must send the job through Chrome control to the named Claude web session."
        },
        "fallback_allowed": {
          "const": false,
          "description": "Do not substitute Claude CLI, a new session, or another named session when the requested session is absent or busy."
        }
      },
      "description": "Runtime-selected builder session. The skill must not hardcode a specific session; when the user specifies one, S4 delegation must use that exact Claude web session."
    },
    "head_sha": {
      "type": "string",
      "minLength": 7
    },
    "spec_path": {
      "type": "string"
    },
    "verification_plan_path": {
      "type": "string",
      "default": ".superpowers/verify/test-design.json"
    },
    "implementation_plan_path": {
      "type": "string"
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "default": [
        "docs/superpowers/specs/**",
        ".superpowers/verify/**",
        ".superpowers/release/**"
      ]
    },
    "instructions": {
      "type": "string",
      "minLength": 1
    },
    "expected_ack": {
      "type": "string",
      "pattern": "^\\.superpowers/orch/outbox/.+\\.ack\\.json$"
    }
  }
}
